---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  summary: string;
  publishedAt: Date;
  updatedAt?: Date;
  project?: string;
  tags: string[];
  lang?: 'en' | 'pt';
  altLangHref?: string;
}

const { title, summary, publishedAt, updatedAt, project, tags, lang = 'en', altLangHref } = Astro.props;
const fmt = (d: Date) => d.toISOString().slice(0, 10);
const altLabel = lang === 'en' ? 'ler em português' : 'read in english';
---
<BaseLayout title={`${title} · spinup.fail`} description={summary}>
  <article>
    <header>
      <h1>{title}</h1>
      <p class="meta">
        <time datetime={publishedAt.toISOString()}>{fmt(publishedAt)}</time>
        {updatedAt && <span> · updated {fmt(updatedAt)}</span>}
        {project && <span> · {project}</span>}
        <span class="lang-pill">{lang}</span>
        {altLangHref && (
          <a
            class="lang-toggle"
            href={altLangHref}
            data-alt-en={lang === 'pt' ? altLangHref : undefined}
            data-alt-pt={lang === 'en' ? altLangHref : undefined}
          >{altLabel}</a>
        )}
      </p>
      <p>{summary}</p>
      {tags.length > 0 && (
        <p>{tags.map((t) => <span class="tag">{t}</span>)}</p>
      )}
      <hr />
    </header>
    <slot />
  </article>
</BaseLayout>
