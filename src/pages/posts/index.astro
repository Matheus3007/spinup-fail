---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const fmt = (d: Date) => d.toISOString().slice(0, 10);
---
<BaseLayout title="Posts · spinup.fail">
  <h1>Posts</h1>
  <p class="meta">Long-form: things I built, what worked, what didn't.</p>
  <ul class="entry-list">
    {posts.map((p) => (
      <li>
        <a href={`/posts/${p.id}`}><span class="title">{p.data.title}</span></a>
        <div class="meta">{fmt(p.data.publishedAt)}{p.data.project && ` · ${p.data.project}`}</div>
        <div class="summary">{p.data.summary}</div>
      </li>
    ))}
  </ul>
</BaseLayout>
