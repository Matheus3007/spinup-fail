---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import PostLayout from '../../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const all = await getCollection('posts', ({ data }) => !data.draft);
  const pt = all.filter((p) => p.data.lang === 'pt' && p.data.translationKey);
  return pt.map((post) => {
    const sibling = all.find(
      (p) => p.data.lang === 'en' && p.data.translationKey === post.data.translationKey,
    );
    return {
      params: { slug: post.data.translationKey! },
      props: { post, enSlug: sibling?.id },
    };
  });
}

interface Props {
  post: CollectionEntry<'posts'>;
  enSlug?: string;
}

const { post, enSlug } = Astro.props;
const { Content } = await render(post);
const enHref = enSlug ? `/posts/${enSlug}` : undefined;
---
<PostLayout
  title={post.data.title}
  summary={post.data.summary}
  publishedAt={post.data.publishedAt}
  updatedAt={post.data.updatedAt}
  project={post.data.project}
  tags={post.data.tags}
  lang="pt"
  altLangHref={enHref}
>
  <Content />
</PostLayout>
